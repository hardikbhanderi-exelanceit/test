_7b4d2901cd","ext":".png","mime":"image/png","path":null,"width":156,"height":156,"size":3.25,"sizeInBytes":3248,"url":"/uploads/thumbnail_diamond_round_ring_7b4d2901cd.png"},"small":{"name":"small_diamond-round-ring","hash":"small_diamond_round_ring_7b4d2901cd","ext":".png","mime":"image/png","path":null,"width":500,"height":500,"size":20.12,"sizeInBytes":20117,"url":"/uploads/small_diamond_round_ring_7b4d2901cd.png"}},"hash":"diamond_round_ring_7b4d2901cd","ext":".png","mime":"image/png","size":29.89,"url":"/uploads/diamond_round_ring_7b4d2901cd.png","previewUrl":null,"provider":"local","provider_metadata":null,"createdAt":"2026-02-10T08:59:03.690Z","updatedAt":"2026-02-10T08:59:03.690Z","publishedAt":"2026-02-10T08:59:03.691Z"}]},{"__component":"shared.testimonial-section","id":24,"section_title":"Stories From Our Clients","isShow":true,"testimonials":[{"id":93,"customer_name":"Sarah & Michael Thompson","review":"<p>We spent months searching for the perfect engagement ring, and Di'aaru exceeded every expectation. The 1.8-carat cushion cut is absolutely breathtaking, and knowing it's ethically created makes it even more special. The quality rivals any mined diamond we saw, but at half the price. Our consultant was patient, knowledgeable, and never pressured us. This ring will be in our family for generations.</p>"},{"id":94,"customer_name":"Jennifer Martinez","review":"<p>As someone who values sustainability, I was thrilled to discover Di'aaru. My anniversary band is exquisite—the emerald cut stones are perfectly matched and the craftsmanship is impeccable. I've received countless compliments, and I love sharing the story of lab-grown diamonds. It's luxury with a conscience.</p>"},{"id":95,"customer_name":"David Chen","review":"<p>I proposed with a Di'aaru solitaire and my fiancée hasn't stopped admiring it! The brilliance is incredible, and the entire process was seamless—from virtual consultation to custom design to delivery. The certificate of authenticity and detailed care instructions show their commitment to excellence.</p>"},{"id":96,"customer_name":"Emily Rodriguez","review":"<p>I inherited my grandmother's jewelry but wanted something uniquely mine for my wedding. Di'aaru helped me design a custom piece incorporating elements from her ring. The result is stunning—a perfect blend of vintage sentiment and modern beauty. The team's artistry and attention to detail are unmatched.</p>"}]},{"__component":"shared.contact-section","id":24,"title":"Begin Your Journey","address":"456 Fifth Avenue, Suite 2800\nNew York, NY 10018\nUnited States","phone":"+1 (212) 555-DIAM (3426)","email":"concierge@diaaru.com","map_link":"https://maps.google.com","isShow":true}]}],"meta":{"pagination":{"page":1,"pageSize":25,"pageCount":1,"total":1}}}